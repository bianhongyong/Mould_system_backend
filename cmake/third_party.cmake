include_guard(GLOBAL)
include(FindPkgConfig)

set(MS_THIRD_PARTY_LINK_TARGETS "")
set(MS_THIRD_PARTY_LIBRARIES "")
set(MS_THIRD_PARTY_INCLUDE_DIRS "")
set(MS_THIRD_PARTY_REPORT_LINES "")

function(ms_record_dependency dep source version include_dir)
  list(APPEND MS_THIRD_PARTY_REPORT_LINES "[deps] ${dep}: source=${source}, version=${version}, include=${include_dir}")
  set(MS_THIRD_PARTY_REPORT_LINES "${MS_THIRD_PARTY_REPORT_LINES}" PARENT_SCOPE)
endfunction()

# protobuf
find_package(Protobuf CONFIG QUIET)
if(TARGET protobuf::libprotobuf)
  list(APPEND MS_THIRD_PARTY_LINK_TARGETS protobuf::libprotobuf)
  get_target_property(_protobuf_inc protobuf::libprotobuf INTERFACE_INCLUDE_DIRECTORIES)
  ms_record_dependency("protobuf" "cmake-config" "${Protobuf_VERSION}" "${_protobuf_inc}")
else()
  find_package(Protobuf QUIET MODULE)
endif()

if(TARGET protobuf::libprotobuf)
  list(APPEND MS_THIRD_PARTY_LINK_TARGETS protobuf::libprotobuf)
  get_target_property(_protobuf_inc protobuf::libprotobuf INTERFACE_INCLUDE_DIRECTORIES)
  if(NOT _protobuf_inc)
    set(_protobuf_inc "${Protobuf_INCLUDE_DIRS}")
  endif()
  ms_record_dependency("protobuf" "cmake-target" "${Protobuf_VERSION}" "${_protobuf_inc}")
elseif(Protobuf_FOUND)
  list(APPEND MS_THIRD_PARTY_LIBRARIES ${Protobuf_LIBRARIES})
  list(APPEND MS_THIRD_PARTY_INCLUDE_DIRS ${Protobuf_INCLUDE_DIRS})
  ms_record_dependency("protobuf" "cmake-module" "${Protobuf_VERSION}" "${Protobuf_INCLUDE_DIRS}")
else()
  pkg_check_modules(PROTOBUF QUIET protobuf)
  if(PROTOBUF_FOUND)
    list(APPEND MS_THIRD_PARTY_LIBRARIES ${PROTOBUF_LINK_LIBRARIES})
    list(APPEND MS_THIRD_PARTY_INCLUDE_DIRS ${PROTOBUF_INCLUDE_DIRS})
    ms_record_dependency("protobuf" "pkg-config" "${PROTOBUF_VERSION}" "${PROTOBUF_INCLUDE_DIRS}")
  else()
    message(FATAL_ERROR "Required dependency not found: protobuf")
  endif()
endif()

