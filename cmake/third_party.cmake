# ONNX Runtime
set(
  ONNXRUNTIME_ROOT
  "/home/honeywell/lib/onnxruntime-linux-x64-gpu-1.21.0"
  CACHE PATH "Root directory of ONNX Runtime installation"
)
set(_onnxruntime_hint_paths
    "${ONNXRUNTIME_ROOT}"
    "${ONNXRUNTIME_ROOT}/lib/cmake/onnxruntime"
    "${ONNXRUNTIME_ROOT}/lib64/cmake/onnxruntime")
set(_onnxruntime_config_file "${ONNXRUNTIME_ROOT}/lib/cmake/onnxruntime/onnxruntimeConfig.cmake")
file(GLOB _onnxruntime_lib64_candidates "${ONNXRUNTIME_ROOT}/lib64/libonnxruntime.so*")
if(EXISTS "${_onnxruntime_config_file}" AND _onnxruntime_lib64_candidates)
  find_package(onnxruntime CONFIG QUIET HINTS ${_onnxruntime_hint_paths})
endif()
if(TARGET onnxruntime::onnxruntime)
  list(APPEND MS_THIRD_PARTY_LINK_TARGETS onnxruntime::onnxruntime)
  get_target_property(_onnxruntime_inc onnxruntime::onnxruntime INTERFACE_INCLUDE_DIRECTORIES)
  ms_record_dependency("onnxruntime" "cmake-config" "unknown" "${_onnxruntime_inc}")
elseif(TARGET onnxruntime)
  list(APPEND MS_THIRD_PARTY_LINK_TARGETS onnxruntime)
  get_target_property(_onnxruntime_inc onnxruntime INTERFACE_INCLUDE_DIRECTORIES)
  ms_record_dependency("onnxruntime" "cmake-config" "unknown" "${_onnxruntime_inc}")
else()
  find_path(
    ONNXRUNTIME_INCLUDE_DIR
    NAMES onnxruntime_c_api.h
    HINTS "${ONNXRUNTIME_ROOT}/include"
  )
  find_library(
    ONNXRUNTIME_LIBRARY
    NAMES onnxruntime
    HINTS "${ONNXRUNTIME_ROOT}/lib" "${ONNXRUNTIME_ROOT}/lib64"
  )
  if(ONNXRUNTIME_INCLUDE_DIR AND ONNXRUNTIME_LIBRARY)
    list(APPEND MS_THIRD_PARTY_LIBRARIES ${ONNXRUNTIME_LIBRARY})
    list(APPEND MS_THIRD_PARTY_INCLUDE_DIRS ${ONNXRUNTIME_INCLUDE_DIR})
    ms_record_dependency("onnxruntime" "manual-root" "1.21.0" "${ONNXRUNTIME_INCLUDE_DIR}")
  else()
    pkg_check_modules(ONNXRUNTIME QUIET onnxruntime)
    if(ONNXRUNTIME_FOUND)
      list(APPEND MS_THIRD_PARTY_LIBRARIES ${ONNXRUNTIME_LINK_LIBRARIES})
      list(APPEND MS_THIRD_PARTY_INCLUDE_DIRS ${ONNXRUNTIME_INCLUDE_DIRS})
      ms_record_dependency("onnxruntime" "pkg-config" "${ONNXRUNTIME_VERSION}" "${ONNXRUNTIME_INCLUDE_DIRS}")
    else()
      message(FATAL_ERROR "Required dependency not found: onnxruntime")
    endif()
  endif()
endif()

